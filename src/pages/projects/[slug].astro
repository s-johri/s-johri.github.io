---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base title={`${project.data.title} · Saurabh Johri`} description={project.data.summary}>
	<header>
		<p class="back"><a href="/">&larr; Saurabh Johri</a></p>
	</header>
	<article class="reveal">
		<h1>{project.data.title}</h1>
		<p class="meta">
			<span class="badge">{project.data.kind === 'case-study' ? 'Case study' : 'Open source'}</span>
			{project.data.repo && <a href={project.data.repo}>View repository &nearr;</a>}
		</p>
		<p class="muted">{project.data.summary}</p>
		<ul class="tags">
			{project.data.tech.map((t) => <li>{t}</li>)}
		</ul>
		<Content />
	</article>
</Base>

<style>
	.back {
		margin: 0 0 2.5rem;
		font-family: var(--mono);
		font-size: 0.8rem;
	}
	article {
		max-width: 50rem;
	}
	article h1 {
		font-size: 1.9rem;
	}
	.meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin: 0.5rem 0;
	}
	.meta a {
		font-family: var(--mono);
		font-size: 0.8rem;
	}
	article :global(h2) {
		border-top: 1px solid var(--border);
		padding-top: 1.75rem;
		margin-top: 2.75rem;
	}
</style>
